# Supabase connection — these two values are SAFE to expose in a frontend app.
# Your data is protected by Row Level Security in the database, not by hiding these.
# Copy this file to ".env" for local development and fill in your project's values.
# (Find them in Supabase: Project Settings -> API)

VITE_SUPABASE_URL=https://YOUR-PROJECT-ref.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# Optional: base path for GitHub Pages. Defaults to "/recruiting/".
# Set to "/" if you use a custom domain.
# VITE_BASE=/recruiting/
